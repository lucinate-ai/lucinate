{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "lucinate"
    }
  },
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "models": [
          {
            "id": "__MODEL__",
            "name": "__MODEL__"
          }
        ]
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "provider": "openrouter",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/__MODEL__"
      }
    }
  },
  "tools": {
    "exec": {
      "security": "full",
      "ask": "off"
    }
  }
}
