{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "lucinate"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:18080",
        "models": [
          {
            "id": "echo",
            "name": "echo"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/echo"
      }
    }
  },
  "tools": {
    "exec": {
      "security": "full",
      "ask": "off"
    }
  }
}
