{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "lucinate"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://host.docker.internal:11434",
        "models": [
          {
            "id": "%MODEL_NAME%",
            "name": "%MODEL_NAME%"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/%MODEL_NAME%"
      }
    }
  },
  "tools": {
    "exec": {
      "security": "full",
      "ask": "off"
    }
  }
}
