# Seed config.yaml for the Hermes integration-test container. The
# entrypoint copies cli-config.yaml.example to $HERMES_HOME/config.yaml
# only if no config exists, so by mounting state/ with this file in
# place we control which provider Hermes uses.
#
# setup-hermes.sh substitutes the placeholders below before writing
# this to state/config.yaml. The "custom" provider routes through any
# OpenAI-compatible base URL — the echo leg points it at the host-side
# echomodel stub, the ollama leg at host-side Ollama. (Verified against
# the live dashboard gateway: an inline custom provider with base_url +
# api_key resolves without `hermes model` interaction.)
model:
  default: "__MODEL__"
  provider: "custom"
  base_url: "__BASE_URL__"
  # The stub/Ollama don't validate the bearer token but Hermes requires
  # the field to be set before it'll route to a custom provider.
  api_key: "lucinate-local"
  # Hermes refuses models whose auto-detected context window is below
  # 64K; small local models default lower, tripping the guardrail.
  # Setting this explicitly bypasses the auto-detect.
  context_length: 65536

# The compression model runs the same context-window guardrail and
# defaults to a different upstream we don't pull in setup. Pin both to
# the same model so a single provider satisfies both code paths.
auxiliary:
  compression:
    model: "__MODEL__"
    context_length: 65536
